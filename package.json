{
  "name": "isekai-terrarium-contracts",
  "version": "0.1.0",
  "type": "module",
  "peerDependencies": {
    "@typespec/compiler": "latest",
    "@typespec/http": "latest",
    "@typespec/openapi": "latest",
    "@typespec/openapi3": "latest",
    "@typespec/rest": "latest"
  },
  "devDependencies": {
    "@typespec/compiler": "^1.9.0",
    "@typespec/http": "^1.9.0",
    "@typespec/openapi": "^1.9.0",
    "@typespec/openapi3": "^1.9.0",
    "@typespec/rest": "^0.79.0",
    "@typespec/versioning": "^0.79.0",
    "yaml": "^2.8.2"
  },
  "scripts": {
    "compile:client": "tsp compile ./src/client/main.tsp && bun scripts/fix-enum-types.ts generated/oas/IsekaiTerrarium.Client.v1.yaml",
    "compile:client:watch": "tsp compile ./src/client/main.tsp --watch",
    "compile:admin": "tsp compile ./src/admin/main.tsp && bun scripts/fix-enum-types.ts generated/oas/IsekaiTerrarium.Admin.v1.yaml",
    "compile:admin:watch": "tsp compile ./src/admin/main.tsp --watch",
    "format:check": "tsp format --check \"**/*.tsp\"",
    "format:fix": "tsp format \"**/*.tsp\""
  },
  "private": true
}
